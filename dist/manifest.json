{
  "manifest_version": 3,
  "key": "",
  "name": "Crosswordle++",
  "version": "1.1.2",
  "description": "Crosswordle solver extension",
  "action": {},
  "content_scripts": [
    {
      "js": [
        "assets/content.ts-B1u-KZ89.js"
      ],
      "matches": [
        "*://*.crosswordle.com/*"
      ],
      "css": [
        "assets/content-Bg23Exm8.css"
      ]
    }
  ],
  "permissions": [
    "storage"
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "*://*.crosswordle.com/*"
      ],
      "resources": [
        "assets/*.css",
        "assets/*.js",
        "assets/content.ts-B1u-KZ89.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
