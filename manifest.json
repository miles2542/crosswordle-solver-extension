{
  "manifest_version": 3,
  "key": "",
  "name": "Crosswordle++",
  "version": "1.2.2",
  "description": "Crosswordle solver extension",
  "action": {},
  "content_scripts": [
    {
      "matches": [
        "*://*.crosswordle.com/*"
      ],
      "js": [
        "src/content.ts"
      ]
    }
  ],
  "permissions": [
    "storage"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*.css",
        "assets/*.js"
      ],
      "matches": [
        "*://*.crosswordle.com/*"
      ]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "crosswordle-plus-plus@miles2542.github.io",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}
